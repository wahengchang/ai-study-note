---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

interface Props {
  category: string;
  posts: CollectionEntry<"blog">[];
}
const { category, posts } = Astro.props;
---
<BaseLayout title={`${category} — Waheng Note`} description={`分類 ${category} 的筆記。`}>
  <section class="max-w-shell mx-auto px-14 max-md:px-6 pt-[120px] pb-[60px] max-md:pt-20">
    <div class="font-mono text-[11px] tracking-[0.3em] uppercase text-fg-2 mb-7">
      分類 · {posts.length} 則筆記
    </div>
    <h1 class="font-display text-[clamp(48px,6vw,80px)] leading-none tracking-tightest">
      <span class="text-accent">{category}</span>
    </h1>
  </section>

  <section class="max-w-shell mx-auto px-14 max-md:px-6 pb-[120px] max-md:pb-[80px]">
    <PostList posts={posts} />
  </section>
</BaseLayout>
