---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

interface Props {
  category: string;
  posts: CollectionEntry<"blog">[];
}
const { category, posts } = Astro.props;
---
<BaseLayout title={`${category} — Waheng Note`} description={`分類 ${category} 的筆記。`}>
  <section class="max-w-prose mx-auto px-6 pt-[140px] pb-[70px] text-center max-md:pt-20">
    <div class="font-mono text-[11px] tracking-[0.35em] uppercase text-fg-2 mb-10">
      Category
    </div>
    <h1 class="font-display text-[clamp(48px,6vw,80px)] leading-[1.02] tracking-tightest">
      {category}
    </h1>
    <p class="text-[16px] text-fg-2 mt-8">
      共 {posts.length} 則筆記
    </p>
  </section>

  <section class="max-w-prose mx-auto px-6 pb-[140px] max-md:pb-[90px]">
    <PostList posts={posts} />
  </section>
</BaseLayout>
