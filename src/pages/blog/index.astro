---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const categories = [...new Set(sorted.map((p) => p.data.category))].sort();
---
<BaseLayout title="所有筆記 — Waheng Note">
  <section class="max-w-prose mx-auto px-6 pt-[140px] pb-[70px] text-center max-md:pt-20">
    <div class="font-mono text-[11px] tracking-[0.35em] uppercase text-fg-2 mb-10">
      Archive
    </div>
    <h1 class="font-display text-[clamp(48px,6vw,80px)] leading-[1.02] tracking-tightest">
      所有筆記，<br />完整索引。
    </h1>
    <p class="text-[16px] text-fg-2 mt-8">
      共 {sorted.length} 則筆記，分布於 {categories.length} 個分類。
    </p>
  </section>

  <section class="max-w-prose mx-auto px-6 pb-[140px] max-md:pb-[90px]">
    <div id="filters" class="flex flex-wrap justify-center gap-2 mb-14">
      <button
        data-filter="ALL"
        data-active="true"
        class="font-mono text-[10px] tracking-[0.15em] uppercase px-3.5 py-2 border border-rule rounded-sm text-fg-2 hover:text-fg hover:border-fg-3 data-[active=true]:text-bg data-[active=true]:bg-fg data-[active=true]:border-fg transition-colors"
      >全部</button>
      {categories.map((c) => (
        <button
          data-filter={c}
          class="font-mono text-[10px] tracking-[0.15em] uppercase px-3.5 py-2 border border-rule rounded-sm text-fg-2 hover:text-fg hover:border-fg-3 data-[active=true]:text-bg data-[active=true]:bg-fg data-[active=true]:border-fg transition-colors"
        >{c}</button>
      ))}
    </div>
    <PostList posts={sorted} />
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const box = document.getElementById("filters");
    if (!box) return;
    box.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-filter]");
      if (!btn) return;
      box.querySelectorAll("[data-filter]").forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "true");
      const f = btn.dataset.filter;
      document.querySelectorAll("[data-category]").forEach((li) => {
        li.style.display = f === "ALL" || li.dataset.category === f ? "" : "none";
      });
    });
  })();
</script>
