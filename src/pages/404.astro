---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="404 — ai-study-note" description="Page not found.">
  <section class="flex flex-col items-start gap-4 py-12">
    <p class="font-mono text-xs text-text-muted">404</p>
    <h1 class="font-mono text-3xl text-brand-orange">Not found.</h1>
    <p class="text-text-primary max-w-lg">
      That page does not exist. It may have been moved, renamed, or never written.
    </p>
    <a
      href={base}
      class="inline-block font-mono text-sm border border-border-default rounded-lg px-4 py-2 text-text-primary hover:border-brand-orange hover:text-brand-orange"
    >
      ← Back home
    </a>
  </section>
</BaseLayout>
