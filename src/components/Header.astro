---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const posts = await getCollection("blog", ({ data }) => !data.draft);
const categories = [...new Set(posts.map((p) => p.data.category))].sort();
---
<header class="border-b border-border-default">
  <nav class="max-w-5xl mx-auto px-4 py-4 font-mono text-sm">
    <div class="flex items-center justify-between mb-3">
      <a href={base} class="text-text-primary hover:text-brand-orange">ai-study-note</a>
      <ul class="flex gap-4">
        <li><a href={base} class="text-text-primary hover:text-brand-orange">Home</a></li>
        <li><a href={`${base}blog/`} class="text-text-primary hover:text-brand-orange">Blog</a></li>
      </ul>
    </div>
    <ul class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-text-muted">
      {categories.map((c) => (
        <li><a href={`${base}categories/${c}/`} class="hover:text-brand-orange">{c}</a></li>
      ))}
    </ul>
  </nav>
</header>
