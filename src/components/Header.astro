---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const posts = await getCollection("blog", ({ data }) => !data.draft);
const categories = [...new Set(posts.map((p) => p.data.category))].sort();
const current = Astro.url.pathname;
const isActive = (path: string) =>
  path === base ? current === base || current === base.slice(0, -1) : current.startsWith(path);
---
<nav
  id="site-nav"
  data-scrolled="false"
  class="sticky top-0 z-50 bg-bg/85 backdrop-blur border-b border-transparent data-[scrolled=true]:border-rule transition-colors"
>
  <div class="max-w-shell mx-auto px-14 max-md:px-6">
    <div class="flex items-center justify-between py-7 max-md:py-5">
      <a
        href={base}
        class="font-display text-[20px] leading-none tracking-tightest text-fg hover:text-accent transition-colors"
      >
        Waheng Note
      </a>

      <ul class="flex gap-7 items-center font-mono text-[12px] tracking-[0.1em] uppercase">
        <li>
          <a
            href={base}
            class={`transition-colors ${isActive(base) ? "text-fg" : "text-fg-2 hover:text-fg"}`}
          >首頁</a>
        </li>
        <li>
          <a
            href={`${base}blog/`}
            class={`transition-colors ${isActive(`${base}blog/`) ? "text-fg" : "text-fg-2 hover:text-fg"}`}
          >筆記</a>
        </li>
        <li>
          <a
            href={`${base}people/`}
            class={`transition-colors ${isActive(`${base}people/`) ? "text-fg" : "text-fg-2 hover:text-fg"}`}
          >名人</a>
        </li>
      </ul>
    </div>

    <ul class="flex flex-wrap gap-x-4 gap-y-1 pb-4 font-mono text-[10px] tracking-[0.1em] uppercase text-fg-3">
      {categories.map((c) => (
        <li>
          <a
            href={`${base}categories/${c}/`}
            class={`hover:text-accent transition-colors ${current === `${base}categories/${c}/` ? "text-accent" : ""}`}
          >{c}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script is:inline>
  (() => {
    const n = document.getElementById("site-nav");
    if (!n) return;
    const on = () => n.setAttribute("data-scrolled", String(scrollY > 8));
    addEventListener("scroll", on, { passive: true });
    on();
  })();
</script>
