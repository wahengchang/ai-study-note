---
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"blog">[];
  title?: string;
}
const { posts, title } = Astro.props;
const base = import.meta.env.BASE_URL;
const fmt = (d: Date) =>
  d.toLocaleDateString("zh-Hant-TW", { year: "numeric", month: "long", day: "numeric" });
---
{title && (
  <h2 class="font-display text-[22px] leading-tight tracking-tightest mb-8 text-center">{title}</h2>
)}
<ul class="max-w-prose mx-auto list-none p-0 border-t border-rule">
  {posts.map((post) => (
    <li data-category={post.data.category} class="border-b border-rule">
      <a
        href={`${base}blog/${post.id}/`}
        class="group block py-8 no-underline"
      >
        <div class="font-mono text-[10px] text-fg-3 tracking-[0.2em] uppercase mb-3 flex gap-3 items-center">
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          <span class="text-rule">·</span>
          <span>{post.data.category}</span>
        </div>

        <h3 class="font-display text-[26px] leading-[1.15] tracking-tightest mb-3 text-fg group-hover:text-accent transition-colors">
          {post.data.title}
        </h3>
        <p class="text-fg-2 text-[15px] leading-relaxed line-clamp-2">
          {post.data.description}
        </p>
      </a>
    </li>
  ))}
</ul>
