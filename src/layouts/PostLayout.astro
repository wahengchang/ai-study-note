---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-none">
    <header class="mb-8 pb-6 border-b border-border-default">
      <h1 class="font-mono text-2xl text-text-primary mb-3">{post.data.title}</h1>
      <p class="text-text-primary mb-4">{post.data.description}</p>
      <div class="flex flex-wrap items-center gap-2 font-mono text-xs text-text-muted">
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
        <span>·</span>
        <a href={`${base}categories/${post.data.category}/`} class="hover:text-brand-orange">
          {post.data.category}
        </a>
        {post.data.tags.length > 0 && <span>·</span>}
        {post.data.tags.map((tag) => (
          <a href={`${base}tags/${tag}/`} class="hover:text-brand-orange">#{tag}</a>
        ))}
      </div>
    </header>
    <div class="prose prose-invert max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
